DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
# Required for video dissection (dissect-video feature)
YOUTUBE_DATA_API_KEY=
GITHUB_PAT=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
ENCRYPTION_KEY=<64-char-hex — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Rate limiting — create a free Redis at upstash.com
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-token

# Cron job security — generate with: openssl rand -base64 32
CRON_SECRET=generate-with-openssl-rand-base64-32

# Razorpay — Subscriptions → Plans (create 6: 3 tiers × monthly/annual) and Settings → API Keys / Webhooks
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STORY_PRO_MONTHLY_PLAN_ID=plan_...
RAZORPAY_STORY_PRO_ANNUAL_PLAN_ID=plan_...
RAZORPAY_CREATOR_PRO_MONTHLY_PLAN_ID=plan_...
RAZORPAY_CREATOR_PRO_ANNUAL_PLAN_ID=plan_...
RAZORPAY_ALL_ACCESS_MONTHLY_PLAN_ID=plan_...
RAZORPAY_ALL_ACCESS_ANNUAL_PLAN_ID=plan_...

# Frontend GrowthBook SDK client key (sdk-...). API host optional — defaults to GrowthBook Cloud CDN if blank.
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-...
NEXT_PUBLIC_GROWTHBOOK_API_HOST=
