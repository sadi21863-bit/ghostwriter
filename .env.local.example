DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
# Required for video dissection (dissect-video feature)
YOUTUBE_DATA_API_KEY=
GITHUB_PAT=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
ENCRYPTION_KEY=<64-char-hex — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Rate limiting — create a free Redis at upstash.com
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-token

# Cron job security — generate with: openssl rand -base64 32
CRON_SECRET=generate-with-openssl-rand-base64-32

# Stripe — create account at stripe.com, get keys from Dashboard > Developers
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STORY_PRO_PRICE_ID=price_...
STRIPE_CREATOR_PRO_PRICE_ID=price_...
STRIPE_ALL_ACCESS_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
